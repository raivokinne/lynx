// Error Handling in Lynx

// throwing errors
let divide = fn(a, b) {
    if b == 0 {
        error "division by zero"
    }
    return a / b
}

// catch wraps a block of code - runs body, catches any error in on block
catch {
    let result = divide(10, 2)
    println("10 / 2 = ", result)
} on err {
    println("caught error: ", err)
}

catch {
    let result = divide(10, 0)
    println("result: ", result)
} on err {
    println("caught: ", err)
}

println("error handling demo complete")